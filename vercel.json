{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "src/index.ts"
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/(.*)",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/api/admin/(.*)",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/api/profile/(.*)",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/api/data/(.*)",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/api/notes/(.*)",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/api/daily/(.*)",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/api/ai/general/(.*)",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/api/health",
      "destination": { "type": "service", "service": "backend" }
    },
    {
      "source": "/(.*)",
      "destination": { "type": "service", "service": "frontend" }
    }
  ]
}
