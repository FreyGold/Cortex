#!/bin/bash

# Get the directory where the script is located
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

# Kill background processes on exit
trap "kill 0" EXIT

echo "🚀 Starting College Knowledge Hub..."

# Start Backend
echo "📡 Starting Backend..."
(cd "$ROOT_DIR/backend" && pnpm dev) &

# Build & Start Frontend
echo "🏗️  Building Frontend..."
(cd "$ROOT_DIR/frontend" && pnpm build) || { echo "❌ Frontend build failed"; exit 1; }

echo "💻 Starting Frontend (production)..."
(cd "$ROOT_DIR/frontend" && pnpm start) &

# Wait for all background processes
wait
